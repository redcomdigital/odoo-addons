<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_sectorial_category_tree" model="ir.ui.view">
        <field name="name">sectorial.category.tree</field>
        <field name="model">sectorial.category</field>
        <field name="arch" type="xml">
            <tree string="Setoriais de Atuação">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_sectorial_category_form" model="ir.ui.view">
        <field name="name">sectorial.category.form</field>
        <field name="model">sectorial.category</field>
        <field name="arch" type="xml">
            <form string="Setorial">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="active" invisible="1"/>
                    <group>
                        <field name="name" placeholder="Ex.: Meio Ambiente"/>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_sectorial_category" model="ir.actions.act_window">
        <field name="name">Setoriais de Atuação</field>
        <field name="res_model">sectorial.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crie novos setoriais de atuação para classificar os contactos filiados.
            </p>
        </field>
    </record>

    <menuitem id="menu_sectorial_category_config"
              name="Setoriais de Atuação"
              parent="contacts.menu_contacts_configuration"
              action="action_sectorial_category"
              sequence="10"
              groups="base.group_system"/>
</odoo>
