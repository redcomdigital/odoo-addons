<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vista em lista -->
    <record id="view_sectorial_category_list" model="ir.ui.view">
        <field name="name">sectorial.category.list</field>
        <field name="model">sectorial.category</field>
        <field name="arch" type="xml">
            <list string="Setoriais de Atuação">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Vista em formulário -->
    <record id="view_sectorial_category_form" model="ir.ui.view">
        <field name="name">sectorial.category.form</field>
        <field name="model">sectorial.category</field>
        <field name="arch" type="xml">
            <form string="Setorial">
                <sheet>
                    <div class="oe_button_box" name="button_box"/>
                    <field name="active" invisible="1"/>
                    <group>
                        <field name="name" placeholder="Ex.: Meio Ambiente"/>
                        <field name="sequence"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Ação de janela -->
    <record id="action_sectorial_category" model="ir.actions.act_window">
        <field name="name">Setoriais de Atuação</field>
        <field name="res_model">sectorial.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Crie novos setoriais de atuação para classificar os contactos filiados.
            </p>
        </field>
    </record>
</odoo>
